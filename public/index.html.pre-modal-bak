  <script>
    (function () {
      var track = document.getElementById('carousel');
      var dotsEl = document.getElementById('carousel-dots');
      var capEl = document.getElementById('carousel-caption');
      if (!track) return;

      var imgs = track.querySelectorAll('img');
      var captions = [
        'Dashboard — your training at a glance',
        'Joint Load — block stress vs ceiling',
        'Readiness, e1RM, and volume trends',
        'Per-joint status breakdown',
        'Film Room — session analytics',
        'Coach Read — block-level analysis'
      ];
      var current = 0;
      var timer;

      imgs.forEach(function (_, i) {
        var btn = document.createElement('button');
        btn.setAttribute('aria-label', 'Slide ' + (i + 1));
        if (i === 0) btn.classList.add('active');
        btn.addEventListener('click', function () { goTo(i); });
        dotsEl.appendChild(btn);
      });

      capEl.textContent = captions[0];

      function goTo(index) {
        imgs[current].classList.remove('active');
        dotsEl.children[current].classList.remove('active');
        current = index;
        imgs[current].classList.add('active');
        dotsEl.children[current].classList.add('active');
        capEl.textContent = captions[current] || '';
        resetTimer();
      }
      function advance() { goTo((current + 1) % imgs.length); }
      function resetTimer() { clearInterval(timer); timer = setInterval(advance, 4000); }
      resetTimer();
    })();

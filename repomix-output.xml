      React.useEffect(() => {
        // Calculate blocks based on meet date
        if (!meetDate) return;

        const meet = new Date(meetDate);
        const now = new Date();

        // Calculate weeks from now to meet
        const weeksToMeet = Math.ceil((meet - now) / (7 * 24 * 60 * 60 * 1000));

        // Standard block structure (can be adjusted)
        const blockStructure = [
          { name: 'Hypertrophy', weeks: Math.ceil(weeksToMeet * 0.35), color: 'bg-blue-600', description: 'Build work capacity' },
          { name: 'Strength', weeks: Math.ceil(weeksToMeet * 0.35), color: 'bg-blue-500', description: 'Heavy loads' },
          { name: 'Peak', weeks: Math.ceil(weeksToMeet * 0.20), color: 'bg-blue-400', description: 'Competition simulation' },
          { name: 'Taper', weeks: Math.ceil(weeksToMeet * 0.10), color: 'bg-blue-300', description: 'Recovery & readiness' }
        ];

        setBlocks(blockStructure);
      }, [meetDate]);

      const totalWeeks = blocks.reduce((sum, block) => sum + block.weeks, 0);

      return (
        <div className="space-y-6">
          {/* DATE PICKER */}
          <div className="bg-slate-800/50 rounded-lg p-6 border border-slate-700">
            <label className="block text-sm font-semibold mb-2 text-slate-300">Select Your Meet Date</label>
            <input
              type="date"
              value={meetDate}
              onChange={(e) => setMeetDate(e.target.value)}
              className="w-full bg-slate-900 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-blue-500 focus:outline-none"
            />
            <p className="text-xs text-slate-400 mt-2">Total macrocycle: {totalWeeks} weeks</p>
          </div>

          {/* TIMELINE BARS */}
          <div className="space-y-4">
            {blocks.map((block, idx) => (
              <div key={idx}>
                <div className="flex justify-between mb-2">
                  <h4 className="font-bold text-white">{block.name}</h4>
                  <span className="text-sm text-slate-400">{block.weeks} weeks</span>
                </div>
                <div className="h-12 rounded-lg overflow-hidden border border-slate-700 flex">
                  <div
                    className={`${block.color} flex items-center justify-center text-white font-semibold`}
                    style={{ width: `${(block.weeks / totalWeeks) * 100}%` }}
                  >
                    {block.weeks > 2 && <span className="text-sm">{block.name}</span>}
                  </div>
                  <div className="flex-1 bg-slate-800/30 flex items-center px-3">
                    <p className="text-xs text-slate-400">{block.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          {/* MEET DATE INDICATOR */}
          <div className="mt-8 p-4 bg-blue-500/10 border border-blue-500/20 rounded-lg">
            <p className="text-sm text-slate-300">
              <span className="font-semibold text-blue-400">Meet Day:</span> {new Date(meetDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </p>
          </div>

          {/* EXPLANATION */}
          <div className="mt-6 p-4 bg-slate-800/50 rounded-lg border border-slate-700">
            <p className="text-sm text-slate-300 leading-relaxed">
              The timeline above shows how CMS structures your training backward from your meet date. Each block has a specific purpose: hypertrophy builds the foundation, strength develops max effort capability, peak trains you to perform, and taper ensures you're fresh when it matters.
            </p>
          </div>
        </div>
      );
    };

    const root = ReactDOM.createRoot(document.getElementById('timeline-root'));
    root.render(<MacrocycleTimeline />);
  </script>

  <footer>
    <div class="shell footer-content">
      <!-- FOOTER GRID -->
      <div class="footer-grid">
        <!-- COLUMN 1: BRAND + CTA -->
        <div class="footer-col">
          <div class="footer-brand">
            <a href="/landing.html" class="brand">Center <span>Mass</span> Strength</a>
            <p class="footer-tagline">Adaptive programming for serious lifters.</p>
          </div>
          <a href="/app" class="btn btn-primary" style="width: fit-content;">Open App</a>
        </div>

        <!-- COLUMN 2: PRODUCT -->
        <div class="footer-col">
          <h4 class="footer-heading">Product</h4>
          <ul class="footer-links">
            <li><a href="/landing.html#programs">Programs</a></li>
            <li><a href="/landing.html#engines">Engines</a></li>
            <li><a href="/landing.html#faq">FAQ</a></li>
            <li><a href="/app">Launch App</a></li>
          </ul>
        </div>

        <!-- COLUMN 3: COMPANY -->
        <div class="footer-col">
          <h4 class="footer-heading">Company</h4>
          <ul class="footer-links">
            <li><a href="/about">About</a></li>
            <li><a href="/blog.html">Blog</a></li>
            <li><a href="mailto:hello@centermassstrength.com">Contact</a></li>
            <li><a href="/support">Support</a></li>
          </ul>
        </div>

        <!-- COLUMN 4: LEGAL -->
        <div class="footer-col">
          <h4 class="footer-heading">Legal</h4>
          <ul class="footer-links">
            <li><a href="/privacy">Privacy</a></li>
            <li><a href="/terms">Terms</a></li>
            <li><a href="/cookies">Cookies</a></li>
            <li><a href="/status">Status</a></li>
          </ul>
        </div>
      </div>

      <!-- FOOTER BOTTOM -->
      <div class="footer-bottom">
        <p class="footer-copy">&copy; 2026 Center Mass Strength. All rights reserved.</p>
        <div class="footer-social">
          <a href="https://twitter.com/centermassstr" title="Twitter" aria-label="Twitter">𝕏</a>
          <a href="https://instagram.com/centermassstr" title="Instagram" aria-label="Instagram">IG</a>
          <a href="https://discord.gg/centermassstr" title="Discord" aria-label="Discord">DC</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

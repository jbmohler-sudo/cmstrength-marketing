  ];

  let activePhase = 0;

  function renderPhaseNav() {
    const nav = document.getElementById('phase-nav');
    nav.innerHTML = phases.map((p, i) => `
      <button
        class="phase-btn${i === activePhase ? ' active' : ''}"
        style="${i === activePhase ? `border-color: ${p.color}; background: ${p.bgColor};` : ''}"
        onclick="setPhase(${i})"
        role="tab"
        aria-selected="${i === activePhase}"
        aria-controls="phase-content"
      >
        <span class="phase-num" style="color: ${p.color};">Phase ${i + 1}</span>
        <span class="phase-name">${p.name}</span>
        <span class="phase-dur">${p.duration}</span>
      </button>
    `).join('');
  }

  function renderPhaseContent() {
    const p = phases[activePhase];
    const container = document.getElementById('phase-content');
    container.innerHTML = `
      <div class="phase-content-card" style="border-color: ${p.borderColor}; animation: fadeSlide 0.2s ease;">
        <div class="phase-content-header" style="background: ${p.bgColor};">
          <div class="phase-meta">
            <div class="phase-icon" style="background: ${p.bgColor}; border: 1px solid ${p.borderColor};">
              <span>${p.icon}</span>
            </div>
            <div>
              <span class="phase-tag" style="background: ${p.tagBg}; color: ${p.tagColor};">${p.label}</span>
            </div>
            <div class="ml-auto text-xs font-mono" style="color: ${p.tagColor};">${p.duration}</div>
          </div>
          <h3 class="text-lg font-black text-white mt-2">${p.name}</h3>
          <p class="phase-description mt-1">${p.description}</p>
        </div>
        <div class="phase-content-body">
          <div class="text-xs font-black uppercase tracking-widest mb-2" style="color: ${p.tagColor};">What's Happening</div>
          <div class="phase-details-grid">
            ${p.details.map(d => `
              <div class="phase-detail-item">
                <div class="phase-detail-dot" style="background: ${p.color};"></div>
                <span>${d}</span>
              </div>
            `).join('')}
          </div>
          <div class="phase-age-note" style="border-color: ${p.borderColor};">
            <span class="phase-age-label" style="color: ${p.tagColor};">50+</span>
            <span class="phase-age-text">${p.ageNote}</span>
          </div>
        </div>
      </div>
    `;
  }

  function renderDots() {
    const dotsEl = document.getElementById('cycle-dots');
    dotsEl.innerHTML = phases.map((p, i) => `
      <div
        class="cycle-dot${i === activePhase ? ' active' : ''}"
        style="${i === activePhase ? `background: ${p.color};` : ''}"
      ></div>
    `).join('');
  }

  function setPhase(idx) {
    activePhase = idx;
    renderPhaseNav();
    renderPhaseContent();
    renderDots();
  }

  function nextPhase() {
    setPhase((activePhase + 1) % phases.length);
  }

  function prevPhase() {
    setPhase((activePhase - 1 + phases.length) % phases.length);
  }

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    const cycle = document.getElementById('cycle-component');
    if (!cycle) return;
    if (e.key === 'ArrowRight') nextPhase();
    if (e.key === 'ArrowLeft') prevPhase();
  });

  // Init
  renderPhaseNav();
  renderPhaseContent();
  renderDots();
</script>

</body>
</html>

      --blue-dark: #008B8B;
      --blue-light: #E0FFFF;
      --surface: #111827;
      --surface-light: #1f2937;
      --surface-lighter: #374151;
      --text-primary: #f3f4f6;
      --text-secondary: #d1d5db;
      --text-tertiary: #9ca3af;
      --accent-glow: rgba(0, 255, 255, 0.15);
      --border: rgba(0, 255, 255, 0.2);
      --orange: #f97316;
      --orange-dim: rgba(249, 115, 22, 0.7);
      --pink: #ec4899;
      --pink-dim: rgba(236, 72, 153, 0.7);
      --grey-dim: rgba(156, 163, 175, 0.4);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
      background: #000;
      color: var(--text-primary);
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 24px;
    }

    /* ── NAV ── */
    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 72px;
    }

    .brand {
      display: block;
      width: 170px;
      height: 36px;
      overflow: hidden;
      flex-shrink: 0;
      text-decoration: none;
    }
    .brand img {
      height: 200px;
      width: auto;
      display: block;
      margin-top: -76px;
      margin-left: -28px;
      filter: drop-shadow(0 0 12px rgba(0, 255, 255, 0.4));
    }

    .launch-btn {
      display: inline-block;
      padding: 10px 20px;
      background: transparent;
      border: 1px solid var(--blue);
      color: var(--blue);
      border-radius: 6px;
      text-decoration: none;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.08em;
      transition: all 0.2s;
    }
    .launch-btn:hover {
      background: var(--accent-glow);
      box-shadow: 0 0 16px rgba(0,255,255,0.25);
    }

    /* ── NAV PILLS ── */
    .method-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 64px;
    }
    .method-nav a {
      padding: 6px 14px;
      border: 1px solid rgba(0,255,255,0.2);
      border-radius: 20px;
      color: var(--text-tertiary);
      font-size: 12px;
      text-decoration: none;
      transition: all 0.2s;
      font-weight: 500;
    }
    .method-nav a:hover, .method-nav a.active {
      border-color: var(--blue);
      color: var(--blue);
      background: var(--accent-glow);
    }

    /* ── HERO ── */
    .eyebrow {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 20px;
    }

    h1 {
      font-size: clamp(36px, 6vw, 56px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
      background: linear-gradient(135deg, #fff 0%, var(--blue-light) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 620px;
      line-height: 1.7;
      margin-bottom: 64px;
    }

    /* ── TRAJECTORY SECTION ── */
    .section { margin-bottom: 72px; }

    .section-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin-bottom: 32px;
    }

    .trajectory-block {
      border-left: 2px solid var(--border);
      padding-left: 28px;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .traj-line {
      font-size: 17px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .traj-line em {
      font-style: normal;
      color: var(--blue);
      font-weight: 700;
    }

    .traj-line strong {
      color: var(--text-primary);
      font-weight: 700;
    }

    .traj-payoff {
      margin-top: 8px;
      padding: 20px 24px;
      background: rgba(0,255,255,0.05);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 17px;
      color: var(--text-primary);
      line-height: 1.7;
    }

    .traj-payoff em {
      font-style: normal;
      color: var(--blue);
      font-weight: 700;
    }

    /* ── CAPABILITIES ── */
    .capabilities {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .cap-row {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      align-items: start;
    }

    .cap-row:first-child { border-top: 1px solid rgba(255,255,255,0.06); }

    .cap-label {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--blue);
      padding-top: 2px;
    }

    .cap-text {
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .cap-text strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    /* ── CHART MOCKUP ── */
    .chart-section {
      margin-bottom: 72px;
    }

    .chart-wrapper {
      background: #0d1117;
      border: 1px solid rgba(0,255,255,0.15);
      border-radius: 12px;
      overflow: hidden;
    }

    .chart-header {
      padding: 20px 24px 0;
    }

    .coach-read-label {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin-bottom: 10px;
    }

    .coach-read-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--blue);
      margin-bottom: 6px;
    }

    .coach-read-body {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.6;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .chart-body {
      padding: 24px 24px 8px;
    }

    .chart-title-row {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin-bottom: 24px;
    }

    .bars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }

    .bar-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .bar-stack {
      width: 100%;
      height: 180px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      position: relative;
    }

    /* Ceiling line */
    .bar-stack::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: rgba(255,255,255,0.15);
      border-top: 1px dashed rgba(255,255,255,0.2);
    }

    .bar-segment {
      width: 100%;
      border-radius: 2px 2px 0 0;
      transition: opacity 0.2s;
    }

    .bar-segment.headroom {
      background: rgba(156, 163, 175, 0.25);
      border: 1px solid rgba(156,163,175,0.2);
    }

    .bar-segment.stress {
      background: var(--orange-dim);
      border-top: 1px solid var(--orange);
    }

    .bar-segment.debt {
      background: var(--pink-dim);
      border-top: 1px solid var(--pink);
    }

    .bar-label {
      font-size: 11px;
      color: var(--text-tertiary);
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    .chart-legend {
      display: flex;
      gap: 20px;
      padding: 12px 0 20px;
      justify-content: center;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-tertiary);
    }

    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 2px;
    }

    .chart-caption {
      margin-top: 16px;
      font-size: 12px;
      color: var(--text-tertiary);
      text-align: center;
      font-style: italic;
    }

    /* ── CTA ── */
    .cta-block {
      text-align: center;
      padding: 64px 24px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .cta-block h2 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .cta-block p {
      font-size: 16px;
      color: var(--text-secondary);
      margin-bottom: 32px;
    }

    .cta-btn {
      display: inline-block;
      padding: 16px 36px;
      background: var(--blue);
      color: #000;
      font-weight: 800;
      font-size: 15px;
      border-radius: 8px;
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: all 0.2s;
    }

    .cta-btn:hover {
      background: var(--blue-light);
      box-shadow: 0 0 30px rgba(0,255,255,0.4);
    }

    /* ── FOOTER ── */
    footer {
      background: #000;
      border-top: 1px solid var(--border);
      margin-top: 40px;
      padding: 48px 0 32px;
    }

    .footer-vault {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      margin-bottom: 32px;
      padding-bottom: 32px;
      border-bottom: 1px solid rgba(0,255,255,0.12);
    }

    .footer-vault h4 {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--blue);
      font-weight: 800;
      margin-bottom: 14px;
    }

    .footer-vault ul { list-style: none; }
    .footer-vault li { margin-bottom: 10px; }
    .footer-vault a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 14px;
      transition: color 0.2s;
    }
    .footer-vault a:hover { color: var(--blue); }

    .footer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 4px;
    }

    .footer-row p { color: var(--text-tertiary); font-size: 13px; }
    .footer-motto {
      color: var(--blue) !important;
      font-weight: 900;
      font-style: italic;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 15px;
      text-shadow: 0 0 12px rgba(0,255,255,0.5);
    }

    /* fixed CTA */
    .fixed-cta {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 9999;
    }

    .fixed-cta a {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #000;
      border: 1px solid var(--blue);
      color: var(--blue);
      font-weight: 700;
      font-size: 13px;
      padding: 12px 22px;
      border-radius: 8px;
      text-decoration: none;
      box-shadow: 0 0 20px rgba(0,255,255,0.2);
      transition: all 0.2s;
    }

    .fixed-cta a:hover {
      background: rgba(0,255,255,0.08);
      box-shadow: 0 0 30px rgba(0,255,255,0.35);
    }

    @media (max-width: 640px) {
      .cap-row { grid-template-columns: 1fr; gap: 8px; }
      .footer-vault { grid-template-columns: 1fr; }
      .bars { gap: 8px; }
    }
  </style>
</head>

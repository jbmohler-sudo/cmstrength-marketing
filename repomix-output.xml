        e.preventDefault();
        errorEl.style.display = 'none';
        submit.textContent = 'LOCKING IN...';
        submit.disabled = true;

        var email   = document.getElementById('beta-email').value.trim();
        var program = document.getElementById('beta-track').value;

        try {
          // Guard: validate program against DB constraint before touching anything
          var VALID_PROGRAMS = ['sbd', 'bench-spec', 'jacked-and-strong'];
          if (!VALID_PROGRAMS.includes(program)) {
            throw new Error('Invalid program selection: ' + program);
          }

          // Step 1: Intent log — write to beta_signups regardless of prior signups
          var { error: dbError } = await client
            .from('beta_signups')
            .insert({ email: email, program_interest: program });

          // 23505 = unique_violation (duplicate email) — not a blocker, continue
          if (dbError && dbError.code !== '23505') throw dbError;

          // Step 2: Magic link — creates the user account if new, sends the link either way
          var { error: authError } = await client.auth.signInWithOtp({
            email: email,
            options: {
              emailRedirectTo: REDIRECT_URL,
              data: { program_interest: program }
            }
          });

          if (authError) throw authError;

          // Both succeeded — show confirmation
          form.style.display = 'none';
          success.style.display = 'block';

        } catch (err) {
          console.error('[beta-signup]', err);
          errorEl.textContent = 'Something went wrong — try again or email us directly.';
          errorEl.style.display = 'block';
          submit.textContent = 'SECURE MY SLOT';
          submit.disabled = false;
        }
      });
    })();
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CMS Blog | Bench Specialization & Strength Training Guides</title>
  <meta
    name="description"
    content="Blog posts about adaptive strength training, periodization, and programming insights from Center Mass Strength."
  >
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #050505;
      --bg-elevated: #0d1320;
      --bg-card: rgba(13, 17, 23, 0.4);
      --border: rgba(56, 189, 248, 0.08);
      --text: #ffffff;
      --muted: #8899a6;
      --blue: #0ea5e9;
      --blue-glow: rgba(14, 165, 233, 0.12);
      --radius: 24px;
      --font: 'Inter', sans-serif;
      --max: 1200px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; background: var(--bg); }

    body {
      font-family: var(--font);
      color: var(--text);
      background-color: var(--bg);
      line-height: 1.6;
      overflow-x: hidden;
    }

    .ambient-glow {
      position: fixed;
      top: -10%;
      left: -10%;
      width: 60%;
      height: 60%;
      background: radial-gradient(circle at 20% 20%, var(--blue-glow), transparent 70%);
      pointer-events: none;
      z-index: -1;
    }

    .shell { width: min(var(--max), calc(100% - 3rem)); margin: 0 auto; }

    /* NAVIGATION */
    header {
      position: sticky;
      top: 0;
      backdrop-filter: blur(12px);
      background: rgba(5, 5, 5, 0.8);
      border-bottom: 1px solid var(--border);
      z-index: 100;
    }

    .nav {
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
    }

    .brand {
      font-weight: 900;
      letter-spacing: -0.02em;
      font-style: italic;
      font-size: 1.4rem;
      color: #fff;
      text-decoration: none;
    }
    .brand span { color: var(--blue); }

    .nav-links {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .nav-links a {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #fff;
    }

    .nav-links a:focus {
      outline: 2px solid var(--blue);
      outline-offset: 2px;
    }


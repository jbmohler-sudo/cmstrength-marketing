          <li><a href="/methodology/the-experience.html#sbd">SBD Competition Prep</a></li>
        </ul>
      </div>
      <div>
        <h4>Launch</h4>
        <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 12px;">Ready to train smarter? Join the exclusive beta.</p>
        <a href="/index.html#join-beta" style="color: var(--blue); font-weight: 700; text-decoration: none;">Claim Your Beta Slot →</a>
      </div>
    </div>
    <div class="footer-row">
      <p>&copy; 2026 CENTER MASS STRENGTH</p>
